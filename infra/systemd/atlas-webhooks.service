[Unit]
Description=Atlas Webhook Delivery Worker
After=network.target postgresql.service redis.service

[Service]
Type=simple
User=atlas
Group=atlas
WorkingDirectory=/opt/atlas
EnvironmentFile=/opt/atlas/.env
ExecStart=/usr/local/bin/atlas-webhooks
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=atlas-webhooks

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/atlas

[Install]
WantedBy=multi-user.target
