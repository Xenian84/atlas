# ── Validator / Chain ──────────────────────────────────────────────────────────
VALIDATOR_RPC_URL=http://127.0.0.1:8899          # Internal RPC on Server A
YELLOWSTONE_GRPC_ENDPOINT=http://SERVER_A_IP:10000
YELLOWSTONE_GRPC_X_TOKEN=                        # Yellowstone auth token (if set)

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://atlas:atlas@localhost:5432/atlas
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas
POSTGRES_DB=atlas

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API ────────────────────────────────────────────────────────────────────────
API_BIND=0.0.0.0:8080
ADMIN_API_KEY=change-me-admin-key
RATE_LIMIT_RPM=300                               # Requests per minute per API key

# ── Indexer ────────────────────────────────────────────────────────────────────
INDEXER_COMMITMENT=confirmed                     # processed|confirmed|finalized
INDEXER_METRICS_BIND=0.0.0.0:9100

# ── Webhooks ───────────────────────────────────────────────────────────────────
WEBHOOK_WORKER_CONCURRENCY=50
WEBHOOK_MAX_ATTEMPTS=5

# ── Intelligence ───────────────────────────────────────────────────────────────
INTEL_RECOMPUTE_COOLDOWN_SECS=60
INTEL_WINDOWS=24h,7d,30d

# ── Explorer ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_CHAIN=x1
ATLAS_API_KEY=change-me-explorer-key            # Key the explorer uses to call atlas-api

# ── Price Oracle ───────────────────────────────────────────────────────────────
# XDex token price API (X1 Mainnet) — no auth required
ATLAS_PRICE_API_URL=https://api.xdex.xyz/api/token-price/price

# ── LLM / Explain (optional) ───────────────────────────────────────────────────
LLM_PROVIDER=none                               # none|openai|anthropic|ollama
LLM_BASE_URL=http://localhost:11434/v1          # Ollama or OpenAI-compatible base
LLM_API_KEY=                                    # Leave empty for Ollama
LLM_MODEL=llama3.2                              # e.g. gpt-4o, claude-3-5-sonnet-20241022

# ── Config paths ───────────────────────────────────────────────────────────────
ATLAS_PROGRAMS_CONFIG=/path/to/atlas/config/programs.yml
ATLAS_SPAM_CONFIG=/path/to/atlas/config/spam.yml
